{
  "$schema": "https://turbo.build/schema.json",
  "extends": ["//"],
  "tasks": {
    "build": {
      "dependsOn": ["build:abis", "build:bin"]
    },
    "build:abis": {
      "dependsOn": ["//#install:modules"],
      "outputs": ["abis/**"]
    },
    "build:bin": {
      "dependsOn": ["//#install:modules"],
      "outputs": ["build/**"]
    },
    "test": {
      "dependsOn": ["build:abis"]
    }
  }
}
