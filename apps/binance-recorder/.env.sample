# Binance recorder consumes Binance's public USDⓈ-M futures websocket streams, so
# no API key is required. This file is only for optional runtime overrides.

# Log verbosity (read by the tracing EnvFilter). binance_sdk is pinned to warn to
# silence its per-keepalive PING/PONG chatter; raise it (e.g. binance_sdk=info) to
# debug the websocket client.
RUST_LOG=info,binance_sdk=warn

# Any AppConfig field can be overridden here with the BINANCE_RECORDER__ prefix
# and a `__` separator, e.g.:
# BINANCE_RECORDER__CLICKHOUSE__URL=http://clickhouse-local:8123
# BINANCE_RECORDER__MARKETS=XAUUSDT,XAGUSDT,TSLAUSDT
