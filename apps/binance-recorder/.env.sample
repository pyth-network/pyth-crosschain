# Binance recorder consumes Binance's public spot websocket streams, so no API
# key is required. This file is only for optional runtime overrides.

# Log verbosity (read by the tracing EnvFilter).
RUST_LOG=info

# Any AppConfig field can be overridden here with the BINANCE_RECORDER__ prefix
# and a `__` separator, e.g.:
# BINANCE_RECORDER__CLICKHOUSE__URL=http://clickhouse-local:8123
# BINANCE_RECORDER__MARKETS=XAUUSDT,XAGUSDT,TSLAUSDT
