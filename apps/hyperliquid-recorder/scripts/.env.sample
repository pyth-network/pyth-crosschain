# L2 snapshot local backfill settings

# Source snapshot dump path (<SOURCE_DIR>/<YYYYMMDD>/<hour>.ndjson.zst)

# Inclusive date range (YYYY-MM-DD)
BACKFILL_START_DATE=2026-03-01
BACKFILL_END_DATE=2026-03-29
BACKFILL_MAX_PARALLELISM=8

# Book shape parameters
N_LEVELS=20
N_SIG_FIGS=0
MANTISSA=0

# ClickHouse HTTP connection settings (clickhouse-connect)
CH_HOST=localhost
# If omitted, defaults to 8123 when CH_SECURE=false and 8443 when CH_SECURE=true.
CH_PORT=8123
CH_USER=recorder
CH_PASSWORD=
CH_SECURE=false
CH_DATABASE=pyth_analytics
CH_L2_SNAPSHOTS_TABLE=hyperliquid_l2_snapshots
