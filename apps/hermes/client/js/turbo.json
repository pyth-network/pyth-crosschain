{
  "$schema": "https://turbo.build/schema.json",
  "extends": ["//"],
  "tasks": {
    "build": {
      "dependsOn": ["build:typescript"]
    },
    "build:typescript": {
      "dependsOn": ["//#install:modules", "^build"],
      "outputs": ["lib/**"]
    },
    "example": {
      "cache": false,
      "dependsOn": ["//#install:modules", "build"]
    },
    "pull:schema": {
      "cache": false,
      "dependsOn": ["//#install:modules"],
      "outputs": ["schema.json"]
    }
  }
}
